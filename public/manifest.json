{
  "name": "CLC Premier Studios",
  "short_name": "CLC Studios",
  "description": "Create, edit, and share music and videos with AI-powered tools. Your creative lab — anytime, anywhere.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#080812",
  "theme_color": "#00D485",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "categories": ["entertainment", "music", "photo", "video"],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/home-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "CLC Premier Studios — Home Dashboard"
    },
    {
      "src": "/screenshots/home-narrow.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "CLC Premier Studios — Mobile View"
    }
  ],
  "shortcuts": [
    {
      "name": "Record",
      "short_name": "Record",
      "description": "Jump straight to the recording studio",
      "url": "/studio",
      "icons": [{ "src": "/icons/shortcut-studio.png", "sizes": "96x96" }]
    },
    {
      "name": "Edit Video",
      "short_name": "Editor",
      "description": "Open the video editor",
      "url": "/editor",
      "icons": [{ "src": "/icons/shortcut-editor.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/editor",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        { "name": "video", "accept": ["video/*"] },
        { "name": "audio", "accept": ["audio/*"] }
      ]
    }
  }
}
